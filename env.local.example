# Copy this file to .env.local for local development,
# and add the same values in Vercel Project Settings > Environment Variables for deployment.

# Public — safe to expose to the browser, used for reading weekly_articles
NEXT_PUBLIC_SUPABASE_URL=https://tkpupxjojfmpyvidofhk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-side only, used in app/api/process-articles/route.js (Step 4)
# to write talking_points back to Supabase. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Secret — server-side only, used in Step 4 to call the LLM for talking points
TOGETHER_API_KEY=

# Secret — server-side only, used for text-to-speech playback of talking points
GEMINI_API_KEY=
